# Docker 环境变量配置
# 复制此文件为 .env.docker 并根据实际情况修改
# ⚠️ 生产环境请务必修改所有默认密码！

# MySQL 数据库配置
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=union_portal
MYSQL_USER=union_user
MYSQL_PASSWORD=change-this-password
MYSQL_PORT=3306

# 应用配置
APP_PORT=3000
ADMIN_SESSION_SECRET=change-this-to-a-random-32-char-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Nginx 配置（生产环境可选）
NGINX_PORT=80
NGINX_HTTPS_PORT=443

# Redis 配置 (可选，如不配置则使用内存缓存)
# 使用 Docker 网络中的 Redis 服务
REDIS_URL=redis://redis:6379
